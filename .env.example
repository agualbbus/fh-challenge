# App / Docker Compose (copy to .env — never commit .env)
# Terraform uses shell env + infra/terraform.tfvars instead (see infra/README.md).

# --- PostgreSQL (LangGraph checkpoints) ---
DATABASE_URL=postgresql://watchtower:watchtower@localhost:5432/watchtower

# --- SQS FIFO (API publish / agent worker consume) ---
SQS_QUEUE_URL=http://localhost:9324/000000000000/freight-watchtower.fifo
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:9324
# AWS_ACCESS_KEY_ID=x
# AWS_SECRET_ACCESS_KEY=x

# --- LLM — OpenRouter via langchain-openrouter ---
MODEL_MODE=mock
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL_PRIMARY=anthropic/claude-sonnet-4
# OPENROUTER_MODEL_FALLBACK=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- SonarQube (local static analysis; optional) ---
# Start: docker compose -f docker-compose.sonar.yml up -d
# See docs/SONARQUBE.md
# SONAR_HOST_URL=http://localhost:9000
# SONAR_TOKEN=squ_...

# --- LangSmith (optional; live runs) ---
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=freight-watchtower
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

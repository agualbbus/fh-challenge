# App / Docker Compose (copy to .env — never commit .env)
# Terraform uses shell env + infra/terraform.tfvars instead (see infra/README.md).

# --- Temporal (worker + API) ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# TEMPORAL_API_KEY=          # required for Temporal Cloud; omit for local compose
TEMPORAL_TASK_QUEUE=freight-watchtower

# --- Model (Phase 2+) ---
MODEL_MODE=mock
# OPENAI_API_KEY=

# --- Langfuse (Phase 2+) ---
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

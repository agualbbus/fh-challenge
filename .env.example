# App / Docker Compose (copy to .env — never commit .env)
# Terraform uses shell env + infra/terraform.tfvars instead (see infra/README.md).

# --- Temporal (worker + API) ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
# TEMPORAL_API_KEY=          # required for Temporal Cloud; omit for local compose
TEMPORAL_TASK_QUEUE=freight-watchtower

# --- LLM — OpenRouter (Phase 2+) ---
MODEL_MODE=mock
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL_PRIMARY=anthropic/claude-sonnet-4
# OPENROUTER_MODEL_FALLBACK=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Langfuse (Phase 2+) ---
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
